{
  "name": "supsub-cli-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "supsub-cli monorepo (cli + hono mock server)",
  "packageManager": "pnpm@10.29.2",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev:cli": "pnpm --filter @supsub/cli dev",
    "dev:mock": "pnpm --filter @supsub/mock dev",
    "build:cli": "pnpm --filter @supsub/cli build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.7.5"
  }
}
